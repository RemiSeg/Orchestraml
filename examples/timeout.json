{
  "name": "timed-out-container",
  "execution": {"type": "container", "image": "alpine:3.21", "command": ["sleep", "60"]},
  "priority": 25,
  "timeout_seconds": 2,
  "max_attempts": 1,
  "retry": {"initial_delay_seconds": 1, "multiplier": 2, "maximum_delay_seconds": 4, "retry_timeouts": false},
  "required_labels": ["shared"],
  "resources": {"cpu_millicores": 100, "memory_mib": 32}
}
